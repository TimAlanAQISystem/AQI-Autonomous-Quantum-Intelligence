# Twilio Credentials
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_here

# Twilio Secondary Account (optional)
TWILIO_A_SID=your_secondary_sid_here
TWILIO_A_TOKEN=your_secondary_token_here
TWILIO_A_CALLER_ID=your_secondary_caller_id

# ElevenLabs API
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Tunnel URL (dynamically set by Cloudflare or ngrok)
PUBLIC_TUNNEL_URL=https://your-tunnel-url.trycloudflare.com

# Webhook URL (Twilio TwiML Bin or deployment URL)
AGENT_X_WEBHOOK_URL=https://handler.twilio.com/twiml/your_twiml_bin_id
