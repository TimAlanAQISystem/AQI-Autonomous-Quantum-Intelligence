# ═══════════════════════════════════════════════════════════════
# AQI Autonomous Intelligence — .gitignore
# Keep repo lean: ONLY source code, configs, and documentation
# ═══════════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
*.egg-info/

# ── Logs & Temp ──
logs/
*.log
*.tmp
*.bak
*.out

# ── Data & State (never commit) ──
*.db
*.sqlite
*.sqlite3
*.jsonl
state/
data/
call_sessions.json
iqcore_dashboard_state.json
merchant_profiles.json
merchant_queue_jan14_archived_*.json
_merchant_queue_GARBAGE_BACKUP.json

# ── Secrets & Keys ──
.env
*.enc
*.key
alan_encryption.key
Alan_Deployment/

# ── System / IDE ──
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Text outputs (but allow specific .txt we force-add) ──
*.txt

# ── Binaries & Executables ──
*.exe
*.dll
*.so
*.dylib
*.zip

# ── Media / Large binaries ──
*.wav
*.mp3
*.mp4
*.avi
*.mov
*.flac
*.ogg
*.pdf
*.csv

# ── Build / Deploy ──
dist/
build/
node_modules/
Procfile

# ── Archives & Backups ──
archive/
_ARCHIVE/
_protected_production/
snapshots/

# ── Diagnostic / one-off scripts (prefixed _) ──
# Already-tracked files (_fire_campaign.py, _preflight_field_validation.py) are NOT affected.
_*.py
_*.json
_tmp_*
_temp_*
distil_patch_*

# ── Frontend / Static assets ──
static/
src/

# ── Launch scripts (OS-specific, not portable) ──
*.bat
*.cmd
*.sh
*.ps1

# ── Large generated docs ──
outcome_attribution_log.jsonl
pghs_events.jsonl
training_knowledge_distilled.json
aqi_inventory/aqi_inventory.json

# ── Twilio API dumps (contain credentials) ──
alan_twilio_check.json
alan_twilio_incoming.json
call_recordings.json

# ── Misc ──
twiml_conversation_relay.xml
=
*.pid
health_dump.json
guardian_heartbeat.json
aqi_ultra_report.json
